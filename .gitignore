# =========================
# GranaCerta (.gitignore)
# =========================

# --- Sistema operacional ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- VS Code ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Variáveis de ambiente / segredos ---
.env
.env.*

# Config do Supabase (frontend)
# Observação: a ANON KEY é pública e pode ser commitada para hosting estático (Vercel).
# NUNCA use/commite a SERVICE ROLE KEY.

# --- Node / Frontend build (caso use no futuro) ---
node_modules/
dist/
build/
coverage/

# --- Python (caso use no futuro) ---
.venv/
venv/
__pycache__/
*.py[cod]

# --- Misc ---
*.tmp
*.swp
*.swo
